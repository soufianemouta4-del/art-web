{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/submit-order", "dest": "/api/server.js" },
    { "src": "/api/orders", "dest": "/api/server.js" },
    { "src": "/api/orders/(.*)", "dest": "/api/server.js" },
    { "src": "/thanks.html", "dest": "/public/thanks.html" },
    { "src": "/admin.html", "dest": "/public/admin.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}